datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// ─── NextAuth Modelleri ──────────────────────────────────────────────────────

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?
  access_token       String?
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?
  session_state      String?
  user               User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id              String           @id @default(cuid())
  name            String?
  email           String?          @unique
  emailVerified   DateTime?
  image           String?
  isAdult         Boolean          @default(false)
  role            String           @default("USER") // USER, ADMIN
  gender          String?          // male, female, other
  accounts        Account[]
  sessions        Session[]
  characters      CharacterDNA[]
  generatedImages GeneratedImage[]
  favoritePrompts FavoritePrompt[]
  outfits         UserOutfit[]
  feedbacks       Feedback[]
  albums          Album[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── SCX Studio Modelleri ────────────────────────────────────────────────────

model CharacterDNA {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name            String?  @default("Ana Karakter")
  isMainCharacter Boolean  @default(false)
  age             String?
  gender          String?  @default("unspecified")
  skinTone        String?
  bodyType        String?
  height          String?
  weight          String?
  hairStyle       String?
  facialFeatures  String?
  faceImages      String?
  poseReference   String?
  view360Image    String?
  noBgImage       String?
  signatureOutfit String?
  expressions     String?  // JSON string for saved expressions
  storedOutfits   String?  // JSON string for saved outfits
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId])
}

model GeneratedImage {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  promptUsed    String
  imageUrl      String
  engineUsed    String   @default("fal_ai_flux_pulid")
  mixerSettings String?
  albumId       String?
  album         Album?   @relation(fields: [albumId], references: [id])
  isFavorite    Boolean  @default(false)
  tags          String?
  createdAt     DateTime @default(now())

  @@index([userId])
}

model PromptTemplate {
  id             Int              @id @default(autoincrement())
  collection     String
  originalPrompt String
  template       String
  defaults       String?
  explanation    String?
  imageUrl       String?
  localPath      String?
  isRefined      Boolean          @default(false)
  isNSFW         Boolean          @default(false)
  favoritedBy    FavoritePrompt[]
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@index([collection])
}

// ─── Gelişmiş Profil & Admin Modelleri ──────────────────────────────────────────

model FavoritePrompt {
  id        String         @id @default(cuid())
  userId    String
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  promptId  Int
  prompt    PromptTemplate @relation(fields: [promptId], references: [id], onDelete: Cascade)
  createdAt DateTime       @default(now())

  @@unique([userId, promptId])
  @@index([userId])
}

model UserOutfit {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String
  description String?
  outfitData  String   // JSON formatında giysi kombinasyonu
  imageUrl    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
}

model Feedback {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String   // SUGGESTION, BUG, COMPLAINT
  subject   String
  message   String
  status    String   @default("OPEN") // OPEN, IN_PROGRESS, RESOLVED, CLOSED
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([status])
}

model Album {
  id          String           @id @default(cuid())
  userId      String
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String
  description String?
  images      GeneratedImage[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([userId])
}
